# =============================================================================
# DocuVault Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# =============================================================================

# --- App ---
# Public URL of your app (used for OAuth redirects and Stripe return URLs)
# Local dev: http://localhost:3000 | Production: your Vercel deployment URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
# Project URL — Supabase Dashboard → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key — Supabase Dashboard → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key (server-only, never expose to client) — same API settings page
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- Supabase Auth / Google OAuth ---
# Create OAuth credentials at Google Cloud Console → APIs & Services → Credentials
# Application type: Web application. Add authorized redirect URI:
#   https://your-project-id.supabase.co/auth/v1/callback
# Enable Google provider in Supabase Dashboard → Authentication → Providers → Google
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# --- Gmail API (separate OAuth for inbox read access) ---
# Same Google Cloud project; create a second OAuth client or reuse with gmail.readonly scope
# Authorized redirect URI for Gmail connect flow: {NEXT_PUBLIC_APP_URL}/api/auth/gmail/callback
GMAIL_CLIENT_ID=your-gmail-oauth-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-gmail-oauth-client-secret
GMAIL_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback

# --- Token encryption ---
# 32-byte hex key for AES-256 encryption of Gmail OAuth tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-encryption-key

# --- Anthropic Claude ---
# API key — console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Stripe ---
# Secret key — Stripe Dashboard → Developers → API keys (use test keys for dev)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Publishable key — same page, safe for client-side Stripe.js
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
# Local dev: use Stripe CLI `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-signing-secret

# Stripe Price IDs for subscription tiers (Products → each product → Pricing → Price ID)
STRIPE_PRICE_ID_PRO=price_your-pro-monthly-price-id
STRIPE_PRICE_ID_BUSINESS=price_your-business-monthly-price-id
